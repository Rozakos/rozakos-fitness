# Copy to backend/.env and adjust. All variables are optional in development.

# Any SQLAlchemy URL; Postgres is a drop-in swap.
ROZAKOS_DATABASE_URL=sqlite:///./fitness.db

# REQUIRED in production: long random string (e.g. `openssl rand -hex 32`).
ROZAKOS_SECRET_KEY=dev-secret-change-me-in-production-0123456789

# JWT lifetime in minutes (default: 7 days).
ROZAKOS_ACCESS_TOKEN_EXPIRE_MINUTES=10080
